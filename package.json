{
  "name": "sts2-mod-manager",
  "version": "1.0.0",
  "description": "Slay the Spire 2 MOD Manager",
  "main": "main.js",
  "scripts": {
    "start": "set ELECTRON_RUN_AS_NODE=&& electron .",
    "build:css": "npx tailwindcss -i ./src/index.css -o ./src/output.css --watch",
    "dev": "concurrently \"npm run build:css\" \"webpack --watch --mode development\" \"wait-on ./dist/renderer.js && set ELECTRON_RUN_AS_NODE=&& electron .\"",
    "build": "npx tailwindcss -i ./src/index.css -o ./src/output.css && webpack --mode production",
    "build:tauri-fe": "npx tailwindcss -i ./src/index.css -o ./src/output.css && webpack --config webpack.tauri.config.js --mode production",
    "tauri": "cargo tauri",
    "tauri:dev": "npm run build:tauri-fe && cargo tauri dev",
    "tauri:build": "npm run build:tauri-fe && cargo tauri build",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.sts2.mod-manager",
    "productName": "STS2 Mod Manager",
    "files": [
      "main.js",
      "preload.js",
      "dist/**/*",
      "src/index.html",
      "src/output.css"
    ],
    "asarUnpack": [
      "node_modules/node-unrar-js/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "STS2ModManager.exe"
    },
    "compression": "maximum"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.0",
    "@electron/packager": "^19.1.0",
    "@tauri-apps/cli": "^2.10.1",
    "autoprefixer": "^10.4.18",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "css-loader": "^6.10.0",
    "electron": "^29.4.6",
    "electron-builder": "^24.13.0",
    "postcss": "^8.4.35",
    "postcss-loader": "^8.1.1",
    "style-loader": "^3.3.4",
    "tailwindcss": "^3.4.1",
    "wait-on": "^7.2.0",
    "webpack": "^5.90.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "lucide-react": "^0.344.0",
    "node-unrar-js": "^2.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
